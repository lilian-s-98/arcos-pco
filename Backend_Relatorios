  '.logo-img{height:38px;object-fit:contain}' +
  '.logo-divisor{width:1px;height:26px;background:#ccc}' +
  '.logo-texto{font-weight:700;color:#001132;font-size:13px}' +
  '.titulo-documento{font-size:13px;font-weight:700;color:#001132;text-transform:uppercase;letter-spacing:.04em}' +
  '.cab-obra{margin-bottom:16px}' +
  '.cab-obra h1{font-size:20px;color:#001132;margin:0 0 4px}' +
  '.cab-obra-sub{font-size:11px;color:#555}' +
  '.cab-obra-secundaria{border-top:2px solid #001132;padding-top:14px}' +
